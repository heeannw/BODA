<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.example.appt">

    <!-- ✅ 인터넷 권한 -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.DayNight"
        tools:targetApi="31">

        <!-- ✅ 앱 시작 화면 (Splash) -->
        <activity
            android:name=".SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ✅ 홈 화면 -->
        <activity android:name=".MainActivity" android:exported="true" />

        <!-- ✅ 데이터 화면 -->
        <activity android:name=".DataActivity" />

        <!-- ✅ 공익 콘텐츠 탐색 화면 -->
        <activity android:name=".ExploreContentActivity" />

        <!-- ✅ 사회문제 리포트 화면 -->
        <activity android:name=".SocialIssueReportActivity" />

        <!-- ✅ 아이디어 제안 화면 -->
        <activity android:name=".IdeaPageActivity" />

        <!-- ✅ 퀴즈 제안 스텝 1 -->
        <activity android:name=".QuizSuggestStep1Activity" />

        <!-- ✅ 퀴즈 제안 스텝 2 -->
        <activity android:name=".QuizSuggestStep2Activity" />

        <!-- ✅ 퀴즈 미리보기 화면 -->
        <activity android:name=".QuizPreviewActivity" />

        <!-- ✅ 마이페이지 -->
        <activity android:name=".MyPageActivity" />

    </application>

</manifest>
